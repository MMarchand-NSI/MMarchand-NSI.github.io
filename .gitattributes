# Normalisation des fins de ligne : LF dans le dépôt, quel que soit l'OS.
* text=auto eol=lf

# Fichiers binaires : ne jamais convertir.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.mp3   binary
*.wav   binary
*.ogg   binary
*.pdf   binary
*.pyc   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
